<!-- Food Preview Modal -->
<div class="modal fade" id="foodModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-body">
                <div class="row">

                    <!-- Image -->
                    <div class="col-md-6 text-center">
                        <img id="modalImage" src="" class="img-fluid rounded shadow">
                    </div>

                    <!-- Details -->
                    <div class="col-md-6">

                        <h3 id="modalTitle"></h3>

                        <!-- Ash Background Description -->
                        <div class="p-3 rounded mb-3" style="background-color:#f1f1f1;">
                            <p id="modalDescription" class="mb-0"></p>
                        </div>

                        <h4 id="modalPrice" class="text-primary mb-3"></h4>

                        <!-- Add to Cart Button -->
                        <button class="btn btn-dark" id="addToCartBtn">
                            🛒 Add to Cart
                        </button>

                    </div>

                </div>
            </div>

        </div>
    </div>
</div>

<!-- To generated Invoice content  -->
<div class="modal fade" id="invoiceModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Invoice</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal">Close</button>
            </div>

            <div class="modal-body" id="invoiceContent">
                <!-- Invoice content generated by JS -->
            </div>

            <div class="modal-footer">
                <button class="btn btn-primary" onclick="printInvoice()">Print Receipt</button>
                <button class="btn btn-success" onclick="sendToBackend()">Confirm Order</button>
            </div>

        </div>
    </div>
</div>

