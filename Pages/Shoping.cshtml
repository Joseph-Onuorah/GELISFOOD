    <!-- modal populate -->
    <script>
        const foodModal = document.getElementById('foodModal');

        foodModal.addEventListener('show.bs.modal', function (event) {
          const button = event.relatedTarget;

          const title = button.getAttribute('data-title');
          const description = button.getAttribute('data-description');
          const price = button.getAttribute('data-price');
          const image = button.getAttribute('data-image');

          document.getElementById('modalTitle').innerText = title;
          document.getElementById('modalDescription').innerText = description;
          document.getElementById('modalPrice').innerText = price;
          document.getElementById('modalImage').src = image;
        });
    </script>

    <!-- filter products/items -->
    <script>
        // Select all filter buttons and menu items
        const filterButtons = document.querySelectorAll('.filters_menu li');
        const menuItems = document.querySelectorAll('.filters-content .grid .col-lg-4');

        filterButtons.forEach(btn => {
          btn.addEventListener('click', () => {
            // Remove 'active' class from all buttons and add to the clicked one
            filterButtons.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');

            const filter = btn.getAttribute('data-filter');

            menuItems.forEach(item => {
              if (filter === '*' || item.classList.contains(filter.slice(1))) {
                item.style.display = 'block';  // show
              } else {
                item.style.display = 'none';   // hide
              }
            });
          });
        });
    </script>

    <!-- SHow table of item picked -->
    <script>
        const foodModal = document.getElementById('foodModal');
        let cart = JSON.parse(localStorage.getItem('cart')) || [];
        let currentItem = {};

        // Load cart when page loads
        document.addEventListener('DOMContentLoaded', renderCart);

        // When modal opens
        foodModal.addEventListener('show.bs.modal', function (event) {
          const button = event.relatedTarget;

          const title = button.getAttribute('data-title');
          const price = parseFloat(button.getAttribute('data-price').replace('$',''));
          const description = button.getAttribute('data-description');
          const image = button.getAttribute('data-image');

          document.getElementById('modalTitle').innerText = title;
          document.getElementById('modalDescription').innerText = description;
          document.getElementById('modalPrice').innerText = "$" + price;
          document.getElementById('modalImage').src = image;

          currentItem = { title, price };
        });

        // Add to Cart
        document.getElementById('addToCartBtn').addEventListener('click', function () {

          const existingItem = cart.find(item => item.title === currentItem.title);

          if (existingItem) {
            existingItem.qty += 1;
          } else {
            cart.push({ ...currentItem, qty: 1 });
          }

          saveCart();
          renderCart();

          const modal = bootstrap.Modal.getInstance(foodModal);
          modal.hide();
        });

        // Render Cart
        function renderCart() {
          const tableBody = document.querySelector('#cartTable tbody');
          tableBody.innerHTML = '';

          let grandTotal = 0;

          cart.forEach((item, index) => {
            const total = item.price * item.qty;
            grandTotal += total;

            tableBody.innerHTML += `
              <tr>
                <td>${item.title}</td>
                <td>$${item.price}</td>
                <td>
                  <input type="number" min="1" value="${item.qty}"
                    onchange="updateQty(${index}, this.value)"
                    class="form-control form-control-sm" style="width:70px;">
                </td>
                <td>$${total.toFixed(2)}</td>
                <td>
                  <button class="btn btn-sm btn-danger" onclick="removeItem(${index})">
                    🗑
                  </button>
                </td>
              </tr>
            `;
          });

          document.getElementById('grandTotal').innerText = grandTotal.toFixed(2);
        }

        // Update Quantity
        function updateQty(index, qty) {
          cart[index].qty = parseInt(qty);
          saveCart();
          renderCart();
        }

        // Remove Item
        function removeItem(index) {
          cart.splice(index, 1);
          saveCart();
          renderCart();
        }

        // Save Cart
        function saveCart() {
          localStorage.setItem('cart', JSON.stringify(cart));
        }

        //4. Update Badge
        function updateBadge() {
          const totalQty = cart.reduce((sum, item) => sum + item.qty, 0);
          const badge = document.getElementById('cartBadge');
          badge.innerText = totalQty;

          // Animation
          badge.classList.add("animate-badge");
          setTimeout(() => badge.classList.remove("animate-badge"), 300);
        }

        // Modify renderCart() to call updateBadge()
        function renderCart() {
          const tableBody = document.querySelector('#cartTable tbody');
          tableBody.innerHTML = '';

          let grandTotal = 0;

          cart.forEach((item, index) => {
            const total = item.price * item.qty;
            grandTotal += total;

            tableBody.innerHTML += `
              <tr>
                <td>${item.title}</td>
                <td>$${item.price}</td>
                <td>
                  <input type="number" min="1" value="${item.qty}"
                    onchange="updateQty(${index}, this.value)"
                    class="form-control form-control-sm" style="width:70px;">
                </td>
                <td>$${total.toFixed(2)}</td>
                <td>
                  <button class="btn btn-sm btn-danger" onclick="removeItem(${index})">
                    🗑
                  </button>
                </td>
              </tr>
            `;
          });

          document.getElementById('grandTotal').innerText = grandTotal.toFixed(2);
          updateBadge();
        }

        //5. Generate Invoice Content
        document.getElementById('invoiceModal')
          .addEventListener('show.bs.modal', function () {

            let html = `
              <h5>Restaurant Invoice</h5>
              <hr>
              <table class="table">
                <thead>
                  <tr>
                    <th>Item</th>
                    <th>Qty</th>
                    <th>Total</th>
                  </tr>
                </thead>
                <tbody>
            `;

            let grandTotal = 0;

            cart.forEach(item => {
              const total = item.price * item.qty;
              grandTotal += total;

              html += `
                <tr>
                  <td>${item.title}</td>
                  <td>${item.qty}</td>
                  <td>$${total.toFixed(2)}</td>
                </tr>
              `;
            });

            html += `
                </tbody>
              </table>
              <h5 class="text-end">Grand Total: $${grandTotal.toFixed(2)}</h5>
            `;

            document.getElementById('invoiceContent').innerHTML = html;
        });

        //6. Print Receipt
        function printInvoice() {
          const content = document.getElementById('invoiceContent').innerHTML;
          const win = window.open('', '', 'width=800,height=600');
          win.document.write(`
            <html>
              <head>
                <title>Receipt</title>
                <link rel="stylesheet"
                 href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
              </head>
              <body class="p-4">
                ${content}
              </body>
            </html>
          `);
          win.document.close();
          win.print();
        }

        //7.Send Cart To ASP.NET Backend
                function sendToBackend() {

            if (cart.length === 0) {
                alert("Cart is empty!");
                return;
            }

            fetch('/Shoping?handler=SaveOrder', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken':
                        document.querySelector('input[name="__RequestVerificationToken"]').value
                },
                body: JSON.stringify(cart)
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error("Network response failed");
                }
                return response.json();
            })
            .then(data => {
                if (data.success) {

                    document.getElementById("invoiceContent").innerHTML +=
                        `<p><strong>Invoice No:</strong> ${data.invoiceId}</p>`;

                    alert(
                        `Order Successful!
                        Invoice No: ${data.invoiceId}
                        Grand Total: $${data.grandTotal.toFixed(2)}`
                    );

                    // Clear cart
                    cart = [];
                    localStorage.removeItem("cart");
                    renderCart();

                    bootstrap.Modal.getInstance(
                        document.getElementById('invoiceModal')
                    ).hide();
                }
                else {
                    alert(data.message);
                }
            })
            .catch(error => {
                console.error("Error:", error);
                alert("Something went wrong.");
            });
        }
    </script>
</body>

</html>